{
  "name": "daily-progress-tracking",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev:backend": "cd backend && go run ./cmd/server",
    "build:backend": "cd backend && go build -o bin/progress-api ./cmd/server",
    "dev:frontend": "npm --workspace frontend run dev",
    "build:frontend": "npm --workspace frontend run build"
  }
}
